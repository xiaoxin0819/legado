<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:overScrollMode="ifContentScrolls"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <io.legado.app.ui.widget.text.TextInputLayout
                android:id="@+id/layout_min_word_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1">

                <io.legado.app.lib.theme.view.ThemeEditText
                    android:id="@+id/edit_min_word_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:digits="0123456789."
                    android:hint="@string/min_word_count_wan"
                    android:inputType="numberDecimal"
                    android:singleLine="true"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

            </io.legado.app.ui.widget.text.TextInputLayout>

            <io.legado.app.ui.widget.text.TextInputLayout
                android:id="@+id/layout_max_word_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1">

                <io.legado.app.lib.theme.view.ThemeEditText
                    android:id="@+id/edit_max_word_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:digits="0123456789."
                    android:hint="@string/max_word_count_wan"
                    android:inputType="numberDecimal"
                    android:singleLine="true"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

            </io.legado.app.ui.widget.text.TextInputLayout>

        </LinearLayout>

        <io.legado.app.ui.widget.text.TextInputLayout
            android:id="@+id/layout_include_kind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <io.legado.app.lib.theme.view.ThemeEditText
                android:id="@+id/edit_include_kind"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/include_kind_keyword"
                android:singleLine="true"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        </io.legado.app.ui.widget.text.TextInputLayout>

        <io.legado.app.ui.widget.text.TextInputLayout
            android:id="@+id/layout_exclude_kind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <io.legado.app.lib.theme.view.ThemeEditText
                android:id="@+id/edit_exclude_kind"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/exclude_kind_keyword"
                android:singleLine="true"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        </io.legado.app.ui.widget.text.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sort"
            android:textColor="@color/primaryText"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/sp_sort_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:theme="@style/Spinner" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
